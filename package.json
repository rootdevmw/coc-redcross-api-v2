{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:members": "ts-node src/scripts/members-test.ts",
    "test:homecells": "ts-node src/scripts/homecells-test.ts",
    "test:ministries": "ts-node src/scripts/ministries-test.ts",
    "test:contents": "ts-node src/scripts/contents-test.ts",
    "test:announcements": "ts-node src/scripts/announcements-test.ts",
    "test:events": "ts-node src/scripts/events-test.ts",
    "test:programs": "ts-node src/scripts/programs-test.ts",
    "test:newsletters": "ts-node src/scripts/newsletters-test.ts",
    "test:streams": "ts-node src/scripts/streams-test.ts",
    "test:auth": "ts-node src/scripts/auth-test.ts",
    "test:roles": "ts-node src/scripts/roles-test.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sendgrid/mail": "^8.1.6",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "axios-cookiejar-support": "^6.0.5",
    "bcrypt": "^6.0.0",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "form-data": "^4.0.5",
    "framer-motion": "^12.38.0",
    "fs": "^0.0.1-security",
    "motion": "^12.38.0",
    "multer": "^2.1.1",
    "passport-jwt": "^4.0.1",
    "prisma": "^7.7.0",
    "react-datepicker": "^9.1.0",
    "react-hook-form": "^7.72.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tough-cookie": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
