generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

//////////////////////////////////////////////////////
// AUTH & USERS
//////////////////////////////////////////////////////

model User {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  deletedAt DateTime? 
  roles  UserRole[]
  member   Member?  @relation("UserMember")

  sessions Session[]

  @@index([deletedAt])
}

model Role {
  id    BigInt @id @default(autoincrement())
  name  String @unique
  deletedAt DateTime?
  users UserRole[]

  @@index([deletedAt])
}

model UserRole {
  userId BigInt
  roleId BigInt

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

//////////////////////////////////////////////////////
// MEMBERS
//////////////////////////////////////////////////////

model Member {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt?  @unique

  prefix       String
  firstName    String
  lastName     String
  phone        String?
  status       String

  baptized     Boolean  @default(false)
  baptismDate  DateTime?

  location     String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  homecellId   BigInt?

  user   User? @relation("UserMember", fields: [userId], references: [id])
  ministries   MemberMinistry[]
  programItems ProgramItem[]
  contents     Content[]

  homecell     Homecell? @relation("HomecellMembers", fields: [homecellId], references: [id])
  leadingHomecells Homecell[] @relation("HomecellLeader")
  leadingMinistries Ministry[] @relation("MinistryLeader")

  homecells Homecell[] @relation("HomecellOverseer")
  overseeingMinistries Ministry[] @relation("MinistryOverseer")

  @@index([deletedAt])
  programTemplateItems ProgramTemplateItem[]
  attentionActions AttentionAction[]
  bio MemberBio?
}

model MemberMinistry {
  memberId   BigInt
  ministryId BigInt

  member   Member   @relation(fields: [memberId], references: [id])
  ministry Ministry @relation(fields: [ministryId], references: [id])

  @@id([memberId, ministryId])
}

//////////////////////////////////////////////////////
// HOMECELLS
//////////////////////////////////////////////////////

model Homecell {
  id         BigInt   @id @default(autoincrement())
  name       String
  location   String?
  leaderId   BigInt?
  overseerId BigInt?
  createdAt  DateTime @default(now())
  deletedAt DateTime?
  leader   Member?  @relation("HomecellLeader", fields: [leaderId], references: [id])
  overseer Member?  @relation("HomecellOverseer", fields: [overseerId], references: [id])
  members  Member[] @relation("HomecellMembers")

  programs Program[]

  @@index([deletedAt])
  programTemplates ProgramTemplate[]
}

model MemberBio {
  id        BigInt  @id @default(autoincrement())

  memberId  BigInt  @unique
  bio       String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member    Member   @relation(fields: [memberId], references: [id])
}

//////////////////////////////////////////////////////
// MINISTRIES
//////////////////////////////////////////////////////

model Ministry {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String? @db.Text
  purpose String @default("Serving together with purpose and unity.")
  leaderId    BigInt?
  overseerId  BigInt?
  slug        String?  @unique
  createdAt   DateTime @default(now())
  deletedAt DateTime?
  leader   Member? @relation("MinistryLeader", fields: [leaderId], references: [id])
  overseer Member? @relation("MinistryOverseer", fields: [overseerId], references: [id])
  members  MemberMinistry[]

  events EventMinistry[]

  @@index([deletedAt])
}

//////////////////////////////////////////////////////
// CONTENT SYSTEM
//////////////////////////////////////////////////////

model ContentType {
  id   BigInt @id @default(autoincrement())
  name String @unique
  deletedAt DateTime?
  contents Content[]

  @@index([deletedAt])
}

model Content {
  id          BigInt   @id @default(autoincrement())
  title       String
  body        String @db.LongText
  typeId      BigInt
  authorId    BigInt?
  status      String
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  deletedAt DateTime?
  type   ContentType @relation(fields: [typeId], references: [id])
  author Member?     @relation(fields: [authorId], references: [id])

  tags       ContentTag[]
  scriptures ScriptureRef[]
  seriesId   BigInt?
  series     Series? @relation(fields: [seriesId], references: [id])

  contentMedia ContentMedia[]

  @@index([typeId])
  @@index([status])
  @@index([deletedAt])
}

model Media {
  id   BigInt @id @default(autoincrement())
  url  String @unique
  type String
  deletedAt DateTime?
  events Event[]
  contentMedia ContentMedia[]
  eventMedia EventMedia[]

  @@index([deletedAt])
}

model ContentMedia {
  contentId BigInt
  mediaId   BigInt
  content Content @relation(fields: [contentId], references: [id])
  media   Media   @relation(fields: [mediaId], references: [id])

  @@id([contentId, mediaId])
}

model EventMedia {
  eventId BigInt
  mediaId BigInt
  event Event @relation(fields: [eventId], references: [id])
  media Media @relation(fields: [mediaId], references: [id])

  @@id([eventId, mediaId])
}

model Tag {
  id   BigInt @id @default(autoincrement())
  name String @unique
  deletedAt DateTime?
  contents ContentTag[]

  @@index([deletedAt])
}

model ContentTag {
  contentId BigInt
  tagId     BigInt
  content Content @relation(fields: [contentId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([contentId, tagId])
}

model Series {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  slug        String?  @unique
  createdAt   DateTime @default(now())
  deletedAt DateTime?
  contents Content[]

  @@index([deletedAt])
}

//////////////////////////////////////////////////////
// SCRIPTURE SYSTEM
//////////////////////////////////////////////////////

model ScriptureRef {
  id        BigInt @id @default(autoincrement())
  contentId BigInt
  deletedAt DateTime?

  book      String
  chapter   Int
  verseFrom Int
  verseTo   Int?
  version   String?

  content Content @relation(fields: [contentId], references: [id])

  @@index([book, chapter])
  @@index([deletedAt])
}

//////////////////////////////////////////////////////
// ANNOUNCEMENTS
//////////////////////////////////////////////////////

model Announcement {
  id         BigInt   @id @default(autoincrement())
  title      String
  body       String @db.Text
  priority   Int
  expiryDate DateTime?
  createdAt  DateTime @default(now())
  deletedAt DateTime?
  targets AnnouncementTarget[]

  @@index([deletedAt])
}

model AnnouncementTarget {
  id             BigInt @id @default(autoincrement())
  announcementId BigInt

  targetType String
  targetId   BigInt
  announcement Announcement @relation(fields: [announcementId], references: [id])

  @@index([targetType, targetId])
}

//////////////////////////////////////////////////////
// EVENTS
//////////////////////////////////////////////////////

model EventType {
  id   BigInt @id @default(autoincrement())
  name String @unique
  deletedAt DateTime?
  events Event[]

  @@index([deletedAt])
}

model Event {
  id          BigInt   @id @default(autoincrement())
  title       String
  description String? @db.Text
  startTime   DateTime
  endTime     DateTime
  location    String?
  slug        String?  @unique
  isCritical  Boolean  @default(false)
  createdAt   DateTime @default(now())
  deletedAt DateTime?
  typeId BigInt

  type        EventType @relation(fields: [typeId], references: [id])
  media       Media[]
  ministries  EventMinistry[]
  eventMedia  EventMedia[]

  @@index([startTime, endTime])
  @@index([deletedAt])
}

model EventMinistry {
  eventId    BigInt
  ministryId BigInt

  event    Event    @relation(fields: [eventId], references: [id])
  ministry Ministry @relation(fields: [ministryId], references: [id])

  @@id([eventId, ministryId])
}

//////////////////////////////////////////////////////
// PROGRAMS
//////////////////////////////////////////////////////

model ProgramType {
  id   BigInt @id @default(autoincrement())
  name String @unique
  deletedAt DateTime?
  programs Program[]

  @@index([deletedAt])
  programTemplates ProgramTemplate[]
}

model Program {
  id         BigInt   @id @default(autoincrement())
  date       DateTime
  typeId     BigInt
  homecellId BigInt?
  location    String?
  createdAt  DateTime @default(now())
  deletedAt DateTime?
  type     ProgramType @relation(fields: [typeId], references: [id])
  homecell Homecell?   @relation(fields: [homecellId], references: [id])

  items ProgramItem[]

  @@index([deletedAt])
}

model ProgramItem {
  id            BigInt @id @default(autoincrement())
  programId     BigInt
  title         String
  description   String? @db.Text
  time          String?
  sequence      Int
  responsibleId BigInt?
  deletedAt DateTime?

  program     Program @relation(fields: [programId], references: [id])
  responsible Member? @relation(fields: [responsibleId], references: [id])

  @@index([programId, sequence])
  @@index([deletedAt])
}

model ProgramTemplate {
  id         BigInt   @id @default(autoincrement())
  name       String
  typeId     BigInt
  homecellId BigInt?
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  type     ProgramType @relation(fields: [typeId], references: [id])
  homecell Homecell?   @relation(fields: [homecellId], references: [id])

  items ProgramTemplateItem[]

  @@index([homecellId])
  @@index([deletedAt])
}

model ProgramTemplateItem {
  id            BigInt @id @default(autoincrement())
  templateId    BigInt
  title         String
  description   String? @db.Text
  time          String?
  sequence      Int
  responsibleId BigInt?
  deletedAt     DateTime?

  template    ProgramTemplate @relation(fields: [templateId], references: [id])
  responsible Member?         @relation(fields: [responsibleId], references: [id])

  @@index([templateId, sequence])
  @@index([deletedAt])
}

//////////////////////////////////////////////////////
// STREAMING
//////////////////////////////////////////////////////

model Stream {
  id        BigInt   @id @default(autoincrement())
  title     String
  isLive    Boolean  @default(false)
  startsAt  DateTime?
  createdAt DateTime @default(now())
  deletedAt DateTime?
  platforms StreamPlatform[]

  @@index([deletedAt])
}

model Platform {
  id   BigInt @id @default(autoincrement())
  name String @unique
  url  String
  deletedAt DateTime?
  streamPlatforms StreamPlatform[]

  @@index([deletedAt])
}

model StreamPlatform {
  streamId   BigInt
  platformId BigInt
  stream   Stream   @relation(fields: [streamId], references: [id])
  platform Platform @relation(fields: [platformId], references: [id])

  @@id([streamId, platformId])
}

//////////////////////////////////////////////////////
// NEWSLETTER
//////////////////////////////////////////////////////

model Newsletter {
  id          BigInt   @id @default(autoincrement())
  title       String
  fileUrl     String
  description String? @db.Text
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  deletedAt DateTime?

  @@index([deletedAt])
}

model Session {
  id          String   @id 
  userId    BigInt
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PasswordResetToken {
  id          BigInt   @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PrayerRequest {
  id          BigInt   @id @default(autoincrement())

  name              String?
  phone             String?
  email             String?

  requestType       String?
  prayerFor         String
  request           String @db.Text

  isUrgent          Boolean  @default(false)
  shareWithElders   Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  status            PrayerRequestStatus @default(PENDING)
}

enum PrayerRequestStatus {
  PENDING
  REVIEWED
  PRAYED_FOR
}

model Visitor {
  id          BigInt   @id @default(autoincrement())

  name                 String
  phone                String?
  email                String?

  visitDate            DateTime
  groupSize            String

  isChurchOfChrist     String?
  language             String?

  hasSpecialNeeds      Boolean  @default(false)
  specialNeedsDetails  String?

  message              String? @db.Text

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  status              VisitorStatus @default(PENDING)
}

enum VisitorStatus {
  PENDING
  CONFIRMED
  COMPLETED
}

model AttentionAction {
  id          BigInt   @id @default(autoincrement())

  type          AttentionType
  referenceId   String

  action        String   // "PRAYED_FOR" | "ACKNOWLEDGED"

  performedById BigInt
  performedBy   Member   @relation(fields: [performedById], references: [id])

  createdAt     DateTime @default(now())

  @@index([referenceId, type])
  @@index([performedById])
}

enum AttentionType {
  PRAYER_REQUEST
  VISITOR
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt?
  action      String   // CREATE, UPDATE, DELETE, PUBLISH, etc.
  entity      String   // "Member", "Content", "Event"
  entityId    String?
  description String?  // human-readable summary

  before      Json?    // previous state
  after       Json?    // new state

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())
}
